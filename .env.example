# Email Configuration for Contact Form
# Get these from your Gmail account settings

# Your Gmail address
EMAIL_USER=your-email@gmail.com

# Your Gmail App Password (not your regular password)
# To get this: 
# 1. Go to Gmail Settings > Accounts and Import > Other Google Account settings
# 2. Go to Security > 2-Step Verification > App passwords
# 3. Generate a new app password for this application
EMAIL_PASS=your-app-password

# Server Port (optional, defaults to 3000)
PORT=3000
